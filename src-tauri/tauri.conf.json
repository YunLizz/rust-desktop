{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "墨韵",
  "version": "0.1.0",
  "identifier": "com.moyin.app",
  "build": {
    "devtools": true,
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "墨韵 - AI 小说创作",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.deepseek.com https://*; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["$HOME/.墨韵/**", "$APPDATA/**", "$LOCALAPPDATA/**"],
        "deny": []
      }
    }
  }
}
